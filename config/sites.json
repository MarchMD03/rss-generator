    "usePuppeteer": true,
    "scraping": {
      "scopeSelector": "#idea-trend .ArticleList_listContainer__m2qg0",
      "itemSelector": ".ArticleList_itemContainer__UNI2Y article.ArticleListItem_container__qIG0Q",
      "fields": {
        "title": {
          "selector": ".ArticleListItem_title__bnVSg",
          "attribute": "text"
        },
        "link": {
          "selector": ".ArticleListItem_link__x5PVw",
          "attribute": "href"
        },
        "author": {
          "selector": ".ArticleListItem_userName__p6vjX a:first-child",
          "attribute": "text"
        },
        "date": {
          "selector": ".ArticleListItem_date___2_aU",
          "attribute": "text"
        },
        "thumbnail": {
          "selector": ".ArticleListItem_avatar__iTEjn img",
          "attribute": "src"
        }
