{
  "qiita": {
    "name": "Qiita週間ランキング",
    "description": "Qiitaの週間記事ランキング",
    "url": "https://qiita.com/Qiita/items/b5c1550c969776b65b9b",
    "language": "ja",
    "outputFile": "qiita-weekly.xml",
    "scraping": {
      "scopeSelector": "body",
      "itemSelector": "h3[data-sourcepos]",
      "fields": {
        "title": {
          "selector": "a:last-child",
          "attribute": "text"
        },
        "link": {
          "selector": "a:last-child",
          "attribute": "href"
        },
        "author": {
          "selector": "+ p a[href^='https://qiita.com/']:not([href*='/tags/'])",
          "attribute": "text"
        }
      }
    },
    "rssConfig": {
      "title": "Qiita週間ランキング",
      "description": "Qiitaの週間人気記事ランキング（日曜・木曜更新）",
      "site_url": "https://qiita.com",
      "feed_url": "",
      "language": "ja",
      "ttl": 60
    }
  },
  "techfeed": {
    "name": "TechFeedデイリー人気記事",
    "description": "TechFeedのデイリー人気記事ランキング",
    "url": "https://techfeed.io/categories/all/selections/daily/{YYYY}/{M}/{D}",
    "language": "ja",
    "outputFile": "techfeed-daily.xml",
    "usePuppeteer": true,
    "scraping": {
      "scopeSelector": "#lang-ja",
      "itemSelector": ".entry-list-item article.entry",
      "fields": {
        "title": {
          "selector": ".entry-title-text",
          "attribute": "text"
        },
        "link": {
          "selector": ".entry-title.text-link-button",
          "attribute": "href"
        },
        "author": {
          "selector": ".rec-channel",
          "attribute": "text"
        },
        "date": {
          "selector": ".rec-date",
          "attribute": "text"
        },
        "thumbnail": {
          "selector": ".entry-thumbnail img",
          "attribute": "src"
        }
      }
    },
    "rssConfig": {
      "title": "TechFeedデイリー人気記事",
      "description": "TechFeedのデイリー人気記事ランキング",
      "site_url": "https://techfeed.io",
      "feed_url": "",
      "language": "ja",
      "ttl": 60
    }
  },
  "zenn-tech": {
    "name": "Zenn Techトレンド",
    "description": "ZennのTechカテゴリのトレンド記事一覧",
    "url": "https://zenn.dev/",
    "language": "ja",
    "outputFile": "zenn-tech.xml",
    "usePuppeteer": true,
    "scraping": {
      "scopeSelector": "#tech-trend .ArticleList_listContainer__m2qg0",
      "itemSelector": ".ArticleList_itemContainer__UNI2Y article.ArticleListItem_container__qIG0Q",
      "fields": {
        "title": {
          "selector": ".ArticleListItem_title__bnVSg",
          "attribute": "text"
        },
        "link": {
          "selector": ".ArticleListItem_link__x5PVw",
          "attribute": "href"
        },
        "author": {
          "selector": ".ArticleListItem_userName__p6vjX a:first-child",
          "attribute": "text"
        },
        "date": {
          "selector": ".ArticleListItem_date___2_aU",
          "attribute": "text"
        },
        "thumbnail": {
          "selector": ".ArticleListItem_avatar__iTEjn img",
          "attribute": "src"
        }
      }
    },
    "rssConfig": {
      "title": "Zenn Techトレンド",
      "description": "ZennのTechカテゴリのトレンド記事一覧",
      "site_url": "https://zenn.dev/",
      "feed_url": "",
      "language": "ja",
      "ttl": 60
    }
  },
  "zenn-idea": {
    "name": "Zenn Ideasトレンド",
